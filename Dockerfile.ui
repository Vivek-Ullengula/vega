# project-vega/Dockerfile.ui
FROM python:3.11-slim

WORKDIR /app

# Install ONLY UI dependencies
RUN pip install --no-cache-dir gradio==5.6.0 requests

# Copy only the UI folder
COPY ui/ ./ui/

# Set environment variables
ENV PYTHONUNBUFFERED=1

# Gradio runs on port 7860 by default
EXPOSE 7860

# Start the Frontend UI
CMD ["python", "ui/gradio_app.py"]
