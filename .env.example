# ==========================================
# Environment variables for local development
# Copy this file to .env and fill in your values
# DO NOT COMMIT your actual .env file to Git!
# ==========================================

# ─── AWS Credentials (Required for local dev outside EC2/Lambda) ───
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ─── UI Configuration ───
# Base URL for the Gradio UI to talk to the FastAPI backend
API_BASE_URL=http://localhost:8000/v1

# ─── AWS Cognito Auth ───
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# ─── DynamoDB Configuration ───
DYNAMODB_TABLE_NAME=CoactionPlatform

# ─── Bedrock & KB Management ───
# KB ID for the primary Underwriting Manuals (Optional: defaults to BRHUTIPVIC in Agent Profile)
BEDROCK_KB_ID=BRHUTIPVIC

# IAM Role required for Bedrock to access S3/RDS when dynamically creating KBs
BEDROCK_KB_ROLE_ARN=

# The embedding model used when syncing S3 documents
EMBEDDING_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.titan-embed-text-v2:0

# ─── RDS Configuration (If managing KB vector DBs via API) ───
RDS_RESOURCE_ARN=
RDS_CREDENTIALS_SECRET_ARN=
